pkgname=lunawolf-icons-magna
pkgver=1.0
pkgrel=2
pkgdesc="Icon Themes for Lunawolf"
arch=('any')
url="https://github.com/LunaWolfLinux/extra-packages"
license=('GPL3')
groups=(lunawolf-icons)
options=(!strip !emptydirs)

prepare() {
	cp -af ../files/. "$srcdir"
}

package() {
	local _iconsdir="$pkgdir"/usr/share/icons
	mkdir -p "$_iconsdir"
	cp -r "$srcdir"/* "$_iconsdir"
}
